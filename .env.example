# FPL Team Comparison — Runtime Configuration
# Copy to .env or set these as environment variables on your host.
# All values shown are the defaults — omit any you don't need to change.

# Server
PORT=3001

# SQLite database path (absolute or relative to server.js)
# For persistent deploys, point this at a mounted volume.
# DB_PATH=./search.db

# Background crawler (indexes the FPL Overall League for name search)
# Set to "false" to disable — app still works, but search only covers
# teams that have been looked up or found via league expansion.
CRAWLER_ENABLED=true
CRAWLER_MAX_PAGES=2000
CRAWLER_DELAY_MS=2000

# League expansion (indexes mini-leagues when a team is looked up)
LEAGUE_DELAY_MS=600

# Admin endpoint auth (/admin/crawler)
# If set, admin endpoints require "Authorization: Bearer <token>".
# If unset, admin endpoints are localhost-only (safe for local dev).
# ADMIN_TOKEN=

# ─── Deployment notes ───
#
# Persistence: The app uses a single SQLite file (search.db).
#   Local dev:  runs in the project directory, no config needed.
#   Railway:    attach a volume, set DB_PATH=/data/search.db
#   Render:     use a persistent disk, set DB_PATH=/var/data/search.db
#   VPS:        any writable path works.
#
# The DB is created automatically on first run. If you have an existing
# search.db, copy it to the DB_PATH location before starting.
#
# Proxy: The server proxies /api/* to fantasy.premierleague.com.
#   No separate reverse proxy is needed for the FPL API.
#   For TLS, put Caddy/nginx in front: proxy :443 → localhost:3001
#
# Minimum deploy: node >= 18, npm install, npm start.
